# Configuración del Motor de Clasificación

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Storage
STORAGE_PATH=data/classifications

# Recalibration
ENABLE_RECALIBRATION=true
MIN_SAMPLES_FOR_RECALIBRATION=100
LEARNING_RATE=0.05
MAX_WEIGHT_ADJUSTMENT=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_ID=your_group_id_here

# Redis (opcional para cache)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# Exchange APIs (opcional para datos real-time)
# BINANCE_API_KEY=your_key
# BINANCE_API_SECRET=your_secret
